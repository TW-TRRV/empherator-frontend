{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "env": {
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array"
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}